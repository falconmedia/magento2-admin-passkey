                    <argument name="branding" xsi:type="object">FalconMedia\AdminPasskey\ViewModel\Branding\Branding</argument>
                </arguments>
            </block>
            <uiComponent name="falconmedia_adminpasskey_diagnostics_listing"/>
        </referenceContainer>
    </body>
</page>
