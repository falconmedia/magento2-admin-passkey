<?php
/**
 * @var \FalconMedia\AdminPasskey\Block\Adminhtml\Login\Page $block
 * @var \Magento\Framework\Escaper $escaper
 */
$copy = $block->getLoginDesignConfig();
$accent = $escaper->escapeHtmlAttr($block->getAccentColor());

// Uploaded stage images (if any) override the bundled defaults via CSS vars.
$stageVars = '';
$stageLight = $block->getStageImageLightUrl();
if ($stageLight !== '') {
    $stageVars .= "--apk-stage-img-light:url('" . $escaper->escapeUrl($stageLight) . "');";
}
$stageDark = $block->getStageImageDarkUrl();
if ($stageDark !== '') {
    $stageVars .= "--apk-stage-img-dark:url('" . $escaper->escapeUrl($stageDark) . "');";
}

$iconFingerprint = '<svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" '
    . 'stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">'
    . '<path d="M12 10a2 2 0 0 0-2 2c0 1.02-.1 2.51-.26 4"></path>'
    . '<path d="M14 13.12c0 2.38 0 6.38-1 8.88"></path><path d="M17.29 21.02c.12-.6.43-2.3.5-3.02"></path>'
    . '<path d="M2 12a10 10 0 0 1 18-6"></path><path d="M2 16h.01"></path>'
    . '<path d="M21.8 16c.2-2 .131-5.354 0-6"></path><path d="M5 19.5C5.5 18 6 15 6 12a6 6 0 0 1 .34-2"></path>'
    . '<path d="M8.65 22c.21-.66.45-1.32.57-2"></path><path d="M9 6.8a6 6 0 0 1 9 5.2v2"></path></svg>';
$iconChevron = '<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" '
    . 'stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg>';
?>
<div class="adminpasskey-login-page adminpasskey-login-page--command"
     style="--apk-accent: <?= $accent ?>;<?= /* @noEscape */ $stageVars ?>"
     data-mage-init='<?= $escaper->escapeHtmlAttr($block->getMageInitJson()) ?>'>
    <?= /* @noEscape */ $block->getThemeToggleHtml() ?>
    <header class="adminpasskey-login-page__topbar">
        <div class="adminpasskey-login-page__topbar-left">
            <?= /* @noEscape */ $block->getLogoHtml('adminpasskey-login-page__topbar-logo') ?>
            <span class="adminpasskey-login-page__env adminpasskey-login-page__env--inline adminpasskey-login-page__env--<?= $escaper->escapeHtmlAttr($block->getEnvironmentMode()) ?>">
                <?= $escaper->escapeHtml($block->getEnvironmentLabel()) ?>
            </span>
        </div>
    </header>

    <div class="adminpasskey-login-page__command-body">
        <section class="adminpasskey-login-page__stage">
            <div class="adminpasskey-login-page__stage-inner">
                <h1 class="adminpasskey-login-page__stage-title">
                    <?= $escaper->escapeHtml(
                        $copy->getPasskeyHeadline() ?: __('eCommerce Management Dashboard')
                    ) ?>
                </h1>
                <p class="adminpasskey-login-page__stage-text">
                    <?= $escaper->escapeHtml(
                        $copy->getPasskeyDescription()
                            ?: __('Sign in to operate your Magento 2 estate. Live platform health shown below.')
                    ) ?>
                </p>
            </div>
        </section>

        <aside class="adminpasskey-login-page__auth-module">
            <div class="adminpasskey-login-page__auth-inner">
                <p class="adminpasskey-login-page__auth-label">
                    <?= $escaper->escapeHtml($copy->getCommandAuthLabel() ?: __('Authentication Required')) ?>
                </p>
                <h2 class="adminpasskey-login-page__auth-title">
                    <?= $escaper->escapeHtml($copy->getSignInTitle() ?: __('Sign in')) ?>
                </h2>

                <?php if ($block->isPasskeyLoginEnabled()): ?>
                    <button type="button"
                            class="adminpasskey-login-page__passkey-card adminpasskey-login__passkey-trigger">
                        <span class="adminpasskey-login-page__passkey-card-icon" aria-hidden="true">
                            <?= /* @noEscape */ $iconFingerprint ?>
                        </span>
                        <span class="adminpasskey-login-page__passkey-card-copy">
                            <strong><?= $escaper->escapeHtml(__('Sign in with a passkey')) ?></strong>
                            <small><?= $escaper->escapeHtml(
                                $copy->getPasskeySubtitle() ?: __('Passwordless · no username')
                            ) ?></small>
                        </span>
                        <span class="adminpasskey-login-page__passkey-card-chevron" aria-hidden="true">
                            <?= /* @noEscape */ $iconChevron ?>
                        </span>
                    </button>
                    <p class="adminpasskey-login-page__status adminpasskey-login__status" aria-live="polite"></p>
                <?php endif; ?>

                <?php if ($block->isPasskeyLoginEnabled() && $block->isPasswordFallbackEnabled()): ?>
                    <div class="adminpasskey-login-page__divider">
                        <span><?= $escaper->escapeHtml(__('or continue with credentials')) ?></span>
                    </div>
                <?php endif; ?>

                <?php if ($block->isPasswordFallbackEnabled()): ?>
                    <?= /* @noEscape */ $block->getCredentialsFormHtml() ?>
                <?php endif; ?>

                <p class="adminpasskey-login-page__footer-note">
                    <?php $footer = $copy->getCommandFooterText(); ?>
                    <?php if ($footer !== ''): ?>
                        <?= $escaper->escapeHtml($footer) ?>
                    <?php else: ?>
                        <?= $escaper->escapeHtml(__('Protected by multi-factor authentication')) ?> ·
                        <a href="#"><?= $escaper->escapeHtml(__('Security policy')) ?></a>
                    <?php endif; ?>
                </p>
            </div>
        </aside>
    </div>
</div>
